# .env.example — Environment variables for Local AgentStudio Pro
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The startup scripts (start-local-agentstudio.sh / .ps1) source this file
# automatically. The Docker Compose file reads it via the env_file mechanism.
#
# Do NOT commit .env to version control — it may contain API keys.

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# URL the Next.js frontend uses to reach the FastAPI backend.
# Default: http://127.0.0.1:8000
# Change this if you run the backend on a different host or port.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Ollama (local LLM inference)
# ---------------------------------------------------------------------------

# Base URL of the Ollama server.
# Default: http://127.0.0.1:11434
# Use http://host.docker.internal:11434 when running inside Docker.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default Ollama model to use for inference.
# Run `ollama pull deepseek-r1:8b` to download this model.
OLLAMA_MODEL=deepseek-r1:8b

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Set to true to allow requests from any origin (default for local dev).
# Set to false and configure ALLOWED_ORIGINS for production-like setups.
CORS_ALLOW_ALL=true

# Comma-separated list of allowed origins when CORS_ALLOW_ALL=false.
# Example: ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Output management
# ---------------------------------------------------------------------------

# Number of days to retain generated output files in backend/output/.
# Files older than this value are eligible for cleanup.
OUTPUT_TTL_DAYS=7

# ---------------------------------------------------------------------------
# OpenClaw gateway
# ---------------------------------------------------------------------------

# Port the OpenClaw gateway listens on.
# Must match the port configured in OpenClawRuntimeService (default: 18789).
OPENCLAW_GATEWAY_PORT=18789

# Directory where OpenClaw stores session state, logs, and workspace data.
# Tilde expansion is supported on macOS/Linux.
# On Windows, use an absolute path: C:\Users\you\.openclaw
OPENCLAW_STATE_DIR=~/.openclaw

# ---------------------------------------------------------------------------
# LLM provider API keys (optional — leave blank to use Ollama only)
# ---------------------------------------------------------------------------

# Anthropic Claude API key.
# Obtain from https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key.
# Obtain from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Base URL for OpenAI-compatible providers (e.g. LM Studio, vLLM, Groq).
# Leave blank if not using an OpenAI-compatible provider.
# OPENAI_COMPAT_BASE_URL=http://127.0.0.1:1234/v1

# ---------------------------------------------------------------------------
# GitHub connector (optional)
# ---------------------------------------------------------------------------

# Personal Access Token for the GitHub connector.
# Required for private repositories and to avoid API rate limits.
# Scopes needed: repo (or public_repo for public repos only)
# GITHUB_TOKEN=ghp_...
